# Mirror for Electron binary downloads (used by @electron/get)
electron_mirror=https://npmmirror.com/mirrors/electron/

# Mirror for electron-builder tool binaries (dmg-builder, etc.)
# Note: ensure-dmg-builder.cjs reads this to pre-download dmg-builder before
# electron-builder runs, because @electron/get incorrectly applies electron_mirror
# to builder-binaries downloads (different CDN path).
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
